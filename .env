# [MySQL 관련 설정]
# root 계정의 비밀번호 (기존 1234 기반)
MYSQL_ROOT_PASSWORD=1234
# 데이터베이스 이름
MYSQL_DATABASE=shadowfit
# 일반 사용자 계정 이름
MYSQL_USER=shadowfit
# 일반 사용자 비밀번호 (기존 shadowfit 기반)
MYSQL_PASSWORD=shadowfit
# 외부 연결 포트 (기본값 3306)
MYSQL_PORT=3306

# [Spring Backend 관련 설정]
# DB 접속 계정 (MYSQL_USER와 동일하게 설정)
DB_USERNAME=shadowfit
# DB 접속 비밀번호 (MYSQL_PASSWORD와 동일하게 설정)
DB_PASSWORD=shadowfit
# JWT 암호화 키 (최소 32자 이상의 랜덤 문자열 추천)
JWT_SECRET=your-very-long-secret-key-for-shadowfit-2026-project
# OpenAI API 키 (실제 sk-... 키가 있다면 입력)
# [API 보안 관련 설정]
INTERNAL_API_TOKEN=shadowfit-internal-secret-2026

