# [MySQL 관련 설정]
# root 계정의 비밀번호
MYSQL_ROOT_PASSWORD=your_root_password_here
# 데이터베이스 이름
MYSQL_DATABASE=
# 일반 사용자 계정 이름
MYSQL_USER=
# 일반 사용자 비밀번호
MYSQL_PASSWORD=your_user_password_here
# 외부 연결 포트
MYSQL_PORT=

# [Spring Backend 관련 설정]
# DB 접속 계정 (MYSQL_USER와 동일하게 설정)
DB_USERNAME=
# DB 접속 비밀번호 (MYSQL_PASSWORD와 동일하게 설정)
DB_PASSWORD=your_user_password_here
# JWT 암호화 키 (최소 32자 이상의 랜덤 문자열 추천)
JWT_SECRET=your_secret_key_at_least_32_characters
# OpenAI API 키 (발급받은 sk-... 키 입력)
OPENAI_API_KEY=your_openai_api_key_here