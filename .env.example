# 이 파일을 .env로 복사한 후 자기 환경에 맞게 값을 채우세요.
# .env는 .gitignore에 등록되어 git에 올라가지 않습니다.
#
# cp .env.example .env

# ===========================================
# [MySQL 컨테이너 설정] - docker-compose.yml에서 사용
# ===========================================
MYSQL_DATABASE=shadowfit
MYSQL_USER=shadowfit

# ↓ 비밀번호는 자기 로컬 환경에 맞게 직접 입력. 운영에서는 강력한 값 사용.
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_PASSWORD=CHANGE_ME

# 호스트(내 PC)에서 노출할 포트.
# 기본값 3306. 다른 MySQL이 이미 3306을 쓰고 있으면 3308 등으로 바꾸세요.
# 컨테이너 내부는 항상 3306이라 이 포트만 바뀝니다.
MYSQL_PORT=3306

# ===========================================
# [Spring Backend - DB 접속] - application.yml에서 사용
# ===========================================
DB_USERNAME=shadowfit

# ↓ MYSQL_PASSWORD와 같은 값으로 입력
DB_PASSWORD=CHANGE_ME

# 백엔드를 도커 컨테이너로 띄우면 아래 두 줄은 비워두거나 주석.
# (yml 기본값 shadowfit-mysql:3306 이 도커 네트워크에서 자동 해석됨)
#
# 백엔드를 PowerShell의 .\gradlew.bat bootRun 으로 직접 실행할 때만 아래 두 줄 사용.
# DB_PORT는 위의 MYSQL_PORT와 같은 값.
DB_HOST=localhost
DB_PORT=3306

# ===========================================
# [JWT] - application.yml에서 사용
# ===========================================
# 반드시 Base64 호환 문자열(A-Z, a-z, 0-9, +, /, =). 하이픈(-) 사용 금지.
# 디코딩 후 32바이트(=256bit) 이상이어야 HMAC-SHA256 키 길이 충족.
#
# 생성 방법:
#   bash:       openssl rand -base64 48
#   PowerShell: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((New-Guid).ToString() + (New-Guid).ToString()))
#
# 절대 이 placeholder 값을 그대로 사용하지 말 것! 모두가 같은 시크릿을 쓰면 위조 가능.
JWT_SECRET=REPLACE_WITH_BASE64_RANDOM_STRING_AT_LEAST_32_BYTES_DECODED

# 토큰 만료 시간(ms). 기본 1시간 / 7일.
JWT_EXPIRATION_TIME=86400
JWT_REFRESH_EXPIRATION_TIME=604800

# ===========================================
# [내부 API 토큰]
# ===========================================
# Spring <-> AI 서버 간 내부 호출 검증용. 무작위 문자열로 생성하여 양쪽 서버에 동일 값 입력.
INTERNAL_API_TOKEN=REPLACE_WITH_RANDOM_SECRET

# ===========================================
# [AI 서버 / gRPC]
# ===========================================
# 도커로 띄우면 아래 두 줄은 비워두거나 주석. (yml 기본값이 도커 네트워크 호스트명)
# 로컬에서 uvicorn으로 띄울 때만 사용.
AI_SERVER_URL=http://localhost:8000
GRPC_FASTAPI_ADDRESS=static://localhost:50051

# ===========================================
# [선택] OpenAI API
# ===========================================
OPENAI_API_KEY=
