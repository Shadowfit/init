# 이 파일을 backend/.env로 복사한 후 자기 환경에 맞게 값을 채우세요.
# cp .env.example .env

# ===========================================
# [MySQL 컨테이너 설정] - docker-compose.yml에서 사용
# ===========================================
MYSQL_DATABASE=shadowfit
MYSQL_USER=shadowfit
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_PASSWORD=CHANGE_ME
MYSQL_PORT=3306

# ===========================================
# [Spring Backend - DB 접속] - application.yml에서 사용
# ===========================================
DB_USERNAME=shadowfit
DB_PASSWORD=CHANGE_ME

# 도커 컨테이너로 띄우면 비워두거나 주석 (yml 기본값 shadowfit-mysql:3306 사용).
# gradlew bootRun 으로 직접 실행할 때만 사용.
DB_HOST=localhost
DB_PORT=3306

# ===========================================
# [JWT] - application.yml에서 사용
# ===========================================
# Base64 호환 문자열, 디코딩 후 32바이트(256bit) 이상 필요. placeholder 그대로 쓰지 말 것.
JWT_SECRET=REPLACE_WITH_BASE64_RANDOM_STRING_AT_LEAST_32_BYTES_DECODED
JWT_EXPIRATION_TIME=86400
JWT_REFRESH_EXPIRATION_TIME=604800

# ===========================================
# [내부 API 토큰]
# ===========================================
# Spring <-> AI 서버 간 내부 호출 검증용.
INTERNAL_API_TOKEN=REPLACE_WITH_RANDOM_SECRET

# ===========================================
# [AI 서버 / gRPC] - 이 모듈만 단독 실행 시 선택 사항
# ===========================================
# AI 서버를 별도로 띄워서 연동할 경우 그 호스트를 입력. 비워두면 AI 연동 기능은 비활성.
AI_SERVER_HOST=
AI_SERVER_GRPC_PORT=8585
AI_SERVER_HTTP_PORT=8000

# ===========================================
# [선택] OpenAI API
# ===========================================
OPENAI_API_KEY=
